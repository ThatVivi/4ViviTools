<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FourRVivi.App.ViewModels"
             x:Class="FourRVivi.App.Views.HomunAiView" x:DataType="vm:HomunAiViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*">
    <TextBlock Grid.Row="0" Text="Homunculus / Merc AI (AzzyAI)" Classes="h1"/>
    <TextBlock Grid.Row="1" Classes="muted" TextWrapping="Wrap"
               Text="Bundled Dr. Azzy AI (a proven mix used across servers). Set your game folder and Apply — files are copied straight into &lt;game&gt;\AI\USER_AI, replacing what's there."/>
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,12">
      <TextBox Width="420" Text="{Binding GameFolder}" Watermark="C:\Games\RagnarokOnline"/>
      <Button Classes="accent" Content="Apply to game" Command="{Binding ApplyCommand}"/>
    </StackPanel>
    <Grid Grid.Row="3" RowDefinitions="Auto,*">
      <TextBlock Grid.Row="0" Text="{Binding Status}" Classes="muted" TextWrapping="Wrap" Margin="0,0,0,8"/>
      <Border Grid.Row="1" Classes="card" Padding="0">
        <ListBox ItemsSource="{Binding Files}" Background="Transparent" FontFamily="Consolas,monospace"/>
      </Border>
    </Grid>
  </Grid>
</UserControl>
