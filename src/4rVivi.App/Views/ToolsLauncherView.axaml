<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="clr-namespace:FourRVivi.App.ViewModels"
             x:Class="FourRVivi.App.Views.ToolsLauncherView" x:DataType="vm:ToolsLauncherViewModel">
  <StackPanel Spacing="14">
    <TextBlock Text="External editors" Classes="h1"/>
    <TextBlock Classes="muted" TextWrapping="Wrap" Text="4rVivi launches the full standalone editors (GRFEditor, ActEditor, Nemo). Set each .exe path once — drop them in a /tools folder next to 4rVivi if you like."/>
    <Border Classes="card">
      <StackPanel Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Text="GRFEditor" Classes="muted" Width="90" VerticalAlignment="Center"/>
          <TextBox Width="400" Text="{Binding GrfEditor}"/>
          <Button Content="Launch" Command="{Binding LaunchCommand}" CommandParameter="GRFEditor"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Text="ActEditor" Classes="muted" Width="90" VerticalAlignment="Center"/>
          <TextBox Width="400" Text="{Binding ActEditor}"/>
          <Button Content="Launch" Command="{Binding LaunchCommand}" CommandParameter="ActEditor"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Text="Nemo" Classes="muted" Width="90" VerticalAlignment="Center"/>
          <TextBox Width="400" Text="{Binding Nemo}"/>
          <Button Content="Launch" Command="{Binding LaunchCommand}" CommandParameter="Nemo"/>
        </StackPanel>
        <Button Classes="accent" Content="Save paths" Command="{Binding SaveCommand}" HorizontalAlignment="Left"/>
        <TextBlock Text="{Binding Status}" Classes="muted"/>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
