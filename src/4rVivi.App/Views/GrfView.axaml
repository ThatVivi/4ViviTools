<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="clr-namespace:FourRVivi.App.ViewModels"
             xmlns:grf="clr-namespace:FourRVivi.Core.Grf;assembly=4rVivi.Core"
             x:Class="FourRVivi.App.Views.GrfView" x:DataType="vm:GrfViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
    <TextBlock Grid.Row="0" Text="GRF browser" Classes="h1"/>
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,12">
      <TextBox Width="420" Text="{Binding Path}" Watermark="C:\rathena\client\data.grf"/>
      <Button Classes="accent" Content="Open" Command="{Binding OpenCommand}"/>
    </StackPanel>
    <TextBox Grid.Row="2" Width="300" HorizontalAlignment="Left" Text="{Binding Filter}" Watermark="filter files…" Margin="0,0,0,8"/>
    <Border Grid.Row="3" Classes="card" Padding="0">
      <ListBox ItemsSource="{Binding Entries}" SelectedItem="{Binding Selected}" Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="grf:GrfEntry">
            <Grid ColumnDefinitions="*,100">
              <TextBlock Grid.Column="0" Text="{Binding Name}"/>
              <TextBlock Grid.Column="1" Text="{Binding RealSize}" Classes="muted"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
      <Button Content="Extract selected" Command="{Binding ExtractCommand}"/>
      <TextBlock Text="{Binding Status}" Classes="muted" VerticalAlignment="Center"/>
    </StackPanel>
  </Grid>
</UserControl>
