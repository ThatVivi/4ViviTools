<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="clr-namespace:FourRVivi.App.ViewModels" xmlns:mem="clr-namespace:FourRVivi.Core.Memory;assembly=4rVivi.Core"
             x:Class="FourRVivi.App.Views.ScannerView" x:DataType="vm:ScannerViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
    <TextBlock Grid.Row="0" Text="Memory scanner" Classes="h1"/>
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,12">
      <ComboBox Width="100" ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}"/>
      <TextBox Width="160" Text="{Binding Value}" Watermark="Current value"/>
      <Button Classes="accent" Content="First scan" Command="{Binding FirstScanCommand}"/>
      <Button Content="New scan" Command="{Binding ResetCommand}"/>
    </StackPanel>
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding CanRefine}" Margin="0,0,0,8">
      <Button Content="Next (exact)" Command="{Binding NextExactCommand}"/>
      <Button Content="Decreased" Command="{Binding DecreasedCommand}"/>
      <Button Content="Increased" Command="{Binding IncreasedCommand}"/>
      <Button Content="Changed" Command="{Binding ChangedCommand}"/>
      <Button Content="Unchanged" Command="{Binding UnchangedCommand}"/>
    </StackPanel>
    <TextBlock Grid.Row="3" Classes="muted" Text="{Binding Status}" TextWrapping="Wrap" Margin="0,0,0,8"/>
    <Border Grid.Row="4" Classes="card" Padding="0">
      <ListBox ItemsSource="{Binding Results}" SelectedItem="{Binding Selected}" Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="mem:ScanHit">
            <Grid ColumnDefinitions="220,*">
              <TextBlock Grid.Column="0" Text="{Binding AddressHex}"/>
              <TextBlock Grid.Column="1" Text="{Binding Display}" Classes="muted"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
    <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
      <Button Content="Use as HP" Command="{Binding UseAsHpCommand}"/>
      <Button Content="Use as MaxHP" Command="{Binding UseAsMaxHpCommand}"/>
      <Button Content="Use as SP" Command="{Binding UseAsSpCommand}"/>
      <Button Content="Use as MaxSP" Command="{Binding UseAsMaxSpCommand}"/>
      <ComboBox Width="130" ItemsSource="{Binding RoleList}" SelectedItem="{Binding SelectedRole}" Margin="16,0,0,0"/>
      <Button Classes="accent" Content="Use as role" Command="{Binding UseAsRoleCommand}"/>
    </StackPanel>
  </Grid>
</UserControl>
