<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FourRVivi.App.ViewModels" xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Class="FourRVivi.App.Views.ScannerView" x:DataType="vm:ScannerViewModel" x:Name="Root">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
    <TextBlock Grid.Row="0" Text="Memory scanner" Classes="h1"/>

    <Border Grid.Row="1" Classes="card" Margin="0,12,0,8">
      <StackPanel Spacing="8">
        <TextBlock Text="Auto-setup (like 4RTools)" FontWeight="SemiBold"/>
        <StackPanel Orientation="Horizontal" Spacing="10">
          <StackPanel><TextBlock Text="Character name (String)" Classes="muted"/><TextBox Width="200" Text="{Binding CharacterName}"/></StackPanel>
          <StackPanel><TextBlock Text="Current HP (Integer)" Classes="muted"/><TextBox Width="140" Text="{Binding CurrentHp}"/></StackPanel>
          <Button Classes="accent" Content="Auto-setup" VerticalAlignment="Bottom" Command="{Binding AutoSetupCommand}"/>
          <Button Content="Read values (OCR)" VerticalAlignment="Bottom" Command="{Binding ReadScreenCommand}"/>
        </StackPanel>
        <TextBlock Text="{Binding Tip}" Classes="muted"/>
        <ItemsControl ItemsSource="{Binding Detected}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="sys:String">
              <Button Content="{Binding}" Margin="0,2,6,0"
                      Command="{ReflectionBinding DataContext.UseDetectedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
          <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
        </ItemsControl>
      </StackPanel>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
      <ComboBox Width="110" ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}"/>
      <TextBox Width="160" Text="{Binding Value}" Watermark="value"/>
      <Button Classes="accent" Content="First scan" Command="{Binding FirstScanCommand}"/>
      <Button Content="New scan" Command="{Binding ResetCommand}"/>
      <Button Content="Re-attach" Command="{Binding ReattachCommand}"/>
    </StackPanel>

    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding CanRefine}" Margin="0,0,0,8">
      <Button Content="Next (exact)" Command="{Binding NextExactCommand}"/>
      <Button Content="Decreased" Command="{Binding DecreasedCommand}"/>
      <Button Content="Increased" Command="{Binding IncreasedCommand}"/>
      <Button Content="Changed" Command="{Binding ChangedCommand}"/>
      <Button Content="Unchanged" Command="{Binding UnchangedCommand}"/>
    </StackPanel>

    <Grid Grid.Row="4" ColumnDefinitions="*,Auto,*">
      <!-- found (left) -->
      <Border Grid.Column="0" Classes="card" Padding="0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Found" Classes="section"/>
          <Grid DockPanel.Dock="Top" ColumnDefinitions="150,*,80" Margin="8,0">
            <TextBlock Grid.Column="0" Text="Address" Classes="muted"/>
            <TextBlock Grid.Column="1" Text="Value" Classes="muted"/>
            <TextBlock Grid.Column="2" Text="Type" Classes="muted"/>
          </Grid>
          <ListBox ItemsSource="{Binding Found}" SelectedItem="{Binding SelectedFound}" Background="Transparent" MaxHeight="340">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:ScanRow">
                <Grid ColumnDefinitions="150,*,80">
                  <TextBlock Grid.Column="0" Text="{Binding AddressHex}"/>
                  <TextBlock Grid.Column="1" Text="{Binding Value}" Classes="muted"/>
                  <TextBlock Grid.Column="2" Text="{Binding Type}" Classes="muted"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- move buttons -->
      <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8" Margin="10,0">
        <Button Content="▶" Command="{Binding MoveToSavedCommand}"/>
        <Button Content="✕" Command="{Binding RemoveSavedCommand}"/>
      </StackPanel>

      <!-- saved (right) -->
      <Border Grid.Column="2" Classes="card" Padding="0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="Saved address list" Classes="section"/>
          <Grid DockPanel.Dock="Top" ColumnDefinitions="120,140,*,90" Margin="8,0">
            <TextBlock Grid.Column="0" Text="Description" Classes="muted"/>
            <TextBlock Grid.Column="1" Text="Address" Classes="muted"/>
            <TextBlock Grid.Column="2" Text="Value" Classes="muted"/>
            <TextBlock Grid.Column="3" Text="Role" Classes="muted"/>
          </Grid>
          <ListBox ItemsSource="{Binding Saved}" SelectedItem="{Binding SelectedSaved}" Background="Transparent" MaxHeight="340">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:ScanRow">
                <Grid ColumnDefinitions="110,130,*,70,30">
                  <TextBox Grid.Column="0" Text="{Binding Description}" Margin="0,0,4,0"/>
                  <TextBlock Grid.Column="1" Text="{Binding AddressHex}" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="2" Text="{Binding Value}" Classes="muted" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="3" Text="{Binding Role}" VerticalAlignment="Center"/>
                  <Button Grid.Column="4" Content="✕"
                          Command="{ReflectionBinding DataContext.RemoveSavedRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>
    </Grid>

    <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
      <TextBlock Text="Assign role:" Classes="muted" VerticalAlignment="Center"/>
      <ComboBox Width="140" ItemsSource="{Binding RoleList}" SelectedItem="{Binding SelectedRole}"/>
      <Button Classes="accent" Content="Apply to profile" Command="{Binding ApplyRoleCommand}"/>
      <TextBlock Text="{Binding Status}" Classes="muted" VerticalAlignment="Center" TextWrapping="Wrap"/>
    </StackPanel>
  </Grid>
</UserControl>
