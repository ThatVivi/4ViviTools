<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="clr-namespace:FourRVivi.App.ViewModels" xmlns:ctrl="clr-namespace:FourRVivi.App.Controls"
             x:Class="FourRVivi.App.Views.SkillsView" x:DataType="vm:SkillsViewModel">
  <StackPanel Spacing="14">
    <TextBlock Text="Skills" Classes="h1"/>
    <Border Classes="card">
      <StackPanel Spacing="10">
        <TextBlock Text="Spammer" FontWeight="SemiBold"/>
        <StackPanel Orientation="Horizontal" Spacing="14">
          <StackPanel><TextBlock Text="Key" Classes="muted"/><ctrl:KeyCaptureBox Width="70" KeyText="{Binding SpamKey}"/></StackPanel>
          <StackPanel><TextBlock Text="Delay ms" Classes="muted"/><NumericUpDown Width="120" Minimum="20" Maximum="10000" Value="{Binding SpamDelay}"/></StackPanel>
        </StackPanel>
      </StackPanel>
    </Border>
    <Border Classes="card">
      <StackPanel Spacing="10">
        <TextBlock Text="Rotation (Switcher / Songs)" FontWeight="SemiBold"/>
        <TextBlock Classes="muted" Text="Comma-separated keys cycled at the spam delay, e.g. F1, F2, F3."/>
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBox Width="260" Text="{Binding RotationKeys}"/>
          <Button Content="Apply rotation" Command="{Binding ApplyRotationCommand}"/>
        </StackPanel>
        <TextBlock Classes="muted" Text="{Binding Status}"/>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
