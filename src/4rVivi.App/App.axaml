<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FourRVivi.App"
             xmlns:conv="clr-namespace:FourRVivi.App.Converters"
             x:Class="FourRVivi.App.App"
             RequestedThemeVariant="Dark">
  <Application.Resources>
    <conv:IdToIconConverter x:Key="IdToIcon"/>
  </Application.Resources>
  <Application.DataTemplates>
    <local:ViewLocator/>
  </Application.DataTemplates>
  <Application.Styles>
    <FluentTheme/>
    <StyleInclude Source="avares://4rVivi/Styles/Colors.axaml"/>
    <StyleInclude Source="avares://4rVivi/Styles/Controls.axaml"/>
  </Application.Styles>
</Application>
